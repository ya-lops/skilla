---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/sections/Hero.astro";
import Advantages from "@/components/sections/Advantages.astro";
import Testimonials from "@/components/sections/Testimonials.astro";
import HowWeWork from "@/components/sections/HowWeWork.astro";
import Partners from "@/components/sections/Partners.astro";
import Thanks from "@/components/sections/Thanks.astro";
import Map from "@/components/sections/Map.astro";
import Blog from "@/components/sections/Blog.astro";
import KP from "@/components/sections/KP.astro";
import Breadcrumbs from "@/components/ui/Breadcrumbs.astro";

import { getBrandData } from "@/lib/api";

const brandData = await getBrandData();
---

<BaseLayout {brandData}>
  <Breadcrumbs class="bg-surface-secondary" items={[{ label: "Главная", href: "/" }, { label: "О компании" }]} />
  <Hero {brandData} type="about" />
  <Advantages {brandData} />
  <Testimonials {brandData} />
  <HowWeWork type="cards" {brandData} />
  <HowWeWork type="timeline" {brandData} />
  <HowWeWork type="flow" {brandData} />
  <Partners {brandData} full />
  <Thanks {brandData} />
  <Map {brandData} />
  <Blog {brandData} />
  <KP {brandData} />
</BaseLayout>
