---
import type { BrandData } from "@/types/brand";

import { STORAGE_PATH } from "@/lib/consts";

interface Props {
  brandData: BrandData;
}

const { brandData } = Astro.props;
---

<section class="testimonials py-8 md:py-10 lg:py-20" data-cmp="Testimonials">
  <div class="container">
    <div class="_testimonials-inner">
      <h2 class="_testimonials-title mb-8 md:12 lg:mb-16">Отзывы наших клиентов</h2>
      <div class="_testimonials-grid grid grid-cols-[repeat(auto-fill,minmax(300px,1fr))] gap-6">
        {
          brandData.feedbacks?.map((testimonial: any) => (
            <div class="_testimonials-card flex flex-col items-start gap-6 p-10 border border-outline rounded-[1.25rem] text-text-secondary">
              <div class="_testimonials-avatar flex items-center justify-center w-19 aspect-square mb-4 rounded-sm overflow-clip">
                {testimonial.avatar ? (
                  <img class="w-full h-full object-cover" src={`${STORAGE_PATH}${testimonial.avatar}`} alt={`Аватар ${testimonial.name} `} loading="lazy"/>
                ) : (
                  <svg
                    width="35"
                    height="42"
                    viewBox="0 0 35 42"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                    xmlns:xlink="http://www.w3.org/1999/xlink"
                  >
                    <rect width="35" height="42" fill="url(#pattern0_261_3898)" />
                    <defs>
                      <pattern id="pattern0_261_3898" patternContentUnits="objectBoundingBox" width="1" height="1">
                        <use xlink:href="#image0_261_3898" transform="matrix(0.0190174 0 0 0.0158794 -4.19979e-08 -0.206992)" />
                      </pattern>
                      <image
                        id="image0_261_3898"
                        width="252"
                        height="100"
                        preserveAspectRatio="none"
                        xlink:href="data:image/png;base64,"
                      />
                    </defs>
                  </svg>
                )}
              </div>

              <p class="_testimonials-name typo-h4">{testimonial.name}</p>

              <p class="_testimonials-text typo-t2">{testimonial.feedback}</p>

              <p class="_testimonials-date text-text-tertiary typo-label">{testimonial.date ?? "12.03.2025"}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

