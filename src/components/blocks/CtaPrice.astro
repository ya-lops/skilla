---
import type { BrandData } from "@/types/brand";

interface Props {
  brandData: BrandData;
}

const { brandData } = Astro.props;

import { getGlobalMinPriceWithDiscount, getDiscountPercent } from "@/utils/price";
import Button from "../ui/Button.astro";
import BlockMessengersLinks from "./BlockMessengersLinks.astro";

const discount = getDiscountPercent(brandData.main.adv_price_percent);

const { price, discountedPrice, showDiscount } = getGlobalMinPriceWithDiscount(brandData.services, discount);
---

<section class="flex flex-col lg:flex-row justify-between gap-6 p-6 lg:p-10 rounded-xl bg-cta-surface text-cta-text" data-cmp="CtaPrice">
  <div>
    <div class="_text typo-h5">Стоимость наших услуг</div>
    <div class="_price mt-6">
      <span class="typo-t1">от</span>
      <span class="typo-h3">
        {
          brandData.main?.adv_price && Number(brandData.main.adv_price) > 0
            ? brandData.main.adv_price
            : showDiscount
              ? discountedPrice
              : price
        }
        <span>₽/час</span>
      </span>
    </div>
  </div>

  <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-20">
    <p class="typo-t2 max-w-[20rem]">Свяжитесь с нами и мы расчитаем точную стоимость под ваши задачи</p>

    <Button class="w-full lg:w-auto" href="#contact" variant="accent" text="Позвонить" />

    <BlockMessengersLinks class="text-text-secondary-inverse" {brandData} />
  </div>
</section>
