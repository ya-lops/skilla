---
import type { BrandData } from "@/types/brand";

import BlockMessengersLinks from "../blocks/BlockMessengersLinks.astro";
import Button from "@/components/ui/Button.astro";

interface NavLink {
  href: string;
  label: string;
  active: boolean;
}

interface Props {
  brandData: BrandData;
  links: NavLink[];
}

const { brandData, links } = Astro.props;
---

<div
  x-show="mobileNavOpen"
  x-cloak
  x-effect="document.documentElement.classList.toggle('overflow-hidden', mobileNavOpen)"
  @keydown.escape.window="mobileNavOpen = false"
  class="fixed inset-0 z-12 lg:hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Мобильное меню"
  data-cmp="MobileNav"
>
  <div
    x-show="mobileNavOpen"
    x-transition:enter="transition-opacity ease-out duration-300"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition-opacity ease-in duration-200"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="absolute inset-0 bg-surface-blur backdrop-blur-xs"
    @click="mobileNavOpen = false"
  >
  </div>

  <div
    x-show="mobileNavOpen"
    x-transition:enter="transition-transform ease-out duration-300"
    x-transition:enter-start="translate-x-full"
    x-transition:enter-end="translate-x-0"
    x-transition:leave="transition-transform ease-in duration-200"
    x-transition:leave-start="translate-x-0"
    x-transition:leave-end="translate-x-full"
    class="absolute right-0 top-0 grid grid-rows-[auto_1fr_auto] h-full w-full flex-col overflow-y-auto bg-mobile-menu-surface text-mobile-menu-text md:w-100 md:max-w-[50vw]"
  >
    <button
      type="button"
      class="absolute right-4 top-4 flex h-10 w-10 items-center justify-center"
      @click="mobileNavOpen = false"
      aria-label="Закрыть меню"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-6 w-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6L6 18"></path>
      </svg>
    </button>

    <div class="py-5 px-4">
      <img
        class="max-h-8 lg:max-h-12.5 w-auto"
        src={brandData.default.logo || "/images/logo-main.webp"}
        alt={`Логотип компании ${brandData.default?.name}`}
      />
    </div>

    <div class="flex flex-col items-center justify-center gap-8 px-6 py-16 text-center">
      <nav aria-label="Мобильная навигация">
        <ul class="flex flex-col items-center gap-6">
          {
            links.map(({ href, label, active }) => (
              <li>
                <a
                  href={href}
                  class:list={["text-xl no-underline text-inherit", { "text-accent": active }]}
                  aria-current={active ? "page" : undefined}
                  x-on:click="mobileNavOpen = false"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <div class="flex flex-col gap-8 py-8 px-4">
      <div class="flex justify-center">
        <BlockMessengersLinks brandData={brandData} />
      </div>

      <div class="grid grid-cols-[repeat(auto-fit,minmax(120px,1fr))] gap-4 items-center">
        <Button href="#personal" text="Личный кабинет" variant="secondary" inverse />
        <Button href="#contact" text="Позвонить" variant="primary" inverse />
      </div>
    </div>
  </div>
</div>
