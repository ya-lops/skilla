<script is:inline>
  function contactModal() {
    return {
      open: false,
      submitting: false,
      form: {
        name: "",
        phone: "",
        agree: false,
      },
      errors: {},

      openModal() {
        this.open = true;
        this.errors = {};
        this.form = { name: "", phone: "", agree: false };
      },

      close() {
        this.open = false;
      },

      validate() {
        this.errors = {};
        if (!this.form.name.trim()) this.errors.name = true;
        if (!this.form.phone.trim()) this.errors.phone = true;
        if (!this.form.agree) this.errors.agree = true;
        return Object.keys(this.errors).length === 0;
      },

      submitForm() {
        if (!this.validate()) return;
        this.submitting = true;

        setTimeout(() => {
          this.submitting = false;
          this.close();

          const isSuccess = Math.random() > 0.3;

          window.dispatchEvent(
            new CustomEvent("show-toast", {
              detail: {
                message: isSuccess ? "Заявка отправлена! Мы скоро свяжемся с вами." : "Ошибка отправки. Попробуйте ещё раз.",
                type: isSuccess ? "success" : "error",
              },
            }),
          );
        }, 1000);
      },
    };
  }
</script>
