---
import IconSvg from "../IconSvg.astro";
---

<div
  x-data="toast()"
  x-show="visible"
  x-cloak
  x-transition:enter="transition ease-out duration-500"
  x-transition:enter-start="opacity-0 -translate-y-full"
  x-transition:enter-end="opacity-100 translate-y-0"
  x-transition:leave="transition ease-in duration-300"
  x-transition:leave-start="opacity-100 translate-y-0"
  x-transition:leave-end="opacity-0 -translate-y-full"
  class="fixed top-30 left-1/2 -translate-x-1/2 z-15 flex items-center gap-4 w-max p-4 rounded-sm typo-t2 bg-toast-surface backdrop-blur-xs text-toast-text"
  @show-toast.window="show($event.detail)"
  data-cmp="BlockToast"
>
  <div
    x-show="type === 'success'"
    class="flex items-center justify-center rounded-2xl py-1 px-2 text-toast-success-text bg-toast-success-bg border border-toast-success-border"
  >
    <IconSvg name="check" />
  </div>

  <div
    x-show="type === 'error'"
    class="flex items-center justify-center rounded-2xl py-1 px-2 text-toast-error-text bg-toast-error-bg border border-toast-error-border"
  >
    <IconSvg name="x" />
  </div>

  <span x-text="message"></span>
</div>
